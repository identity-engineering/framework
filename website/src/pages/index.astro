---
import Layout from '../layouts/Layout.astro';
import GravityScene from '../components/hero/GravityScene';
import MassScene from '../components/concepts/MassScene';
import CurvatureScene from '../components/concepts/CurvatureScene';
import GravitationScene from '../components/concepts/GravitationScene';
import ProbesScene from '../components/concepts/ProbesScene';
---

<Layout title="Identity Engineering">
	<main>
		<!-- Hero -->
		<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
			<GravityScene client:load />

			<div class="relative z-10 text-center max-w-4xl mx-auto px-6">
				<h1 class="text-7xl md:text-[6.5rem] font-bold tracking-tighter leading-[0.9] mb-8">
					<span class="bg-gradient-to-r from-violet-400 via-purple-300 to-cyan-400 bg-clip-text text-transparent">
						Identity Engineering
					</span>
				</h1>
				<p class="text-xl md:text-2xl text-white/50 max-w-2xl mx-auto font-light">
					A science-grounded framework for consciously shaping human identities in the AI era.
				</p>

				<div class="flex gap-4 mt-14 justify-center">
					<a href="#concepts"
					   class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white font-medium hover:bg-white/20 transition">
						Explore the concepts
					</a>
					<a href="/framework"
					   class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-white/10 text-white/50 hover:text-white hover:border-white/30 transition">
						Read the framework
					</a>
				</div>
			</div>

			<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30">
				<span class="text-xs uppercase tracking-[3px]">Scroll</span>
				<div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent animate-pulse"></div>
			</div>
		</section>

		<!-- Concepts -->
		<section id="concepts">

			<!-- Mass -->
			<div class="relative min-h-screen flex items-center">
				<div class="absolute inset-0">
					<MassScene client:visible />
				</div>
				<div class="relative z-10 max-w-7xl mx-auto px-8 w-full grid md:grid-cols-2 gap-16 items-center">
					<div>
						<div class="text-sm uppercase tracking-[4px] text-violet-400/70 mb-4">01</div>
						<h2 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Mass</h2>
						<p class="text-lg text-white/60 leading-relaxed max-w-md">
							The depth and substance of your personal and professional stake. Not volume — but density and weight. The heavier your identity mass, the stronger your gravitational pull on reality.
						</p>
					</div>
					<div></div>
				</div>
			</div>

			<!-- Curvature -->
			<div class="relative min-h-screen flex items-center">
				<div class="absolute inset-0">
					<CurvatureScene client:visible />
				</div>
				<div class="relative z-10 max-w-7xl mx-auto px-8 w-full grid md:grid-cols-2 gap-16 items-center">
					<div></div>
					<div class="md:text-right">
						<div class="text-sm uppercase tracking-[4px] text-cyan-400/70 mb-4">02</div>
						<h2 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Curvature</h2>
						<p class="text-lg text-white/60 leading-relaxed max-w-md md:ml-auto">
							How a strong vision warps what appears possible or inevitable. Like mass bends spacetime, identity mass bends the fabric of your reality — pulling opportunities toward your trajectory.
						</p>
					</div>
				</div>
			</div>

			<!-- Gravitation -->
			<div class="relative min-h-screen flex items-center">
				<div class="absolute inset-0">
					<GravitationScene client:visible />
				</div>
				<div class="relative z-10 max-w-7xl mx-auto px-8 w-full grid md:grid-cols-2 gap-16 items-center">
					<div>
						<div class="text-sm uppercase tracking-[4px] text-violet-400/70 mb-4">03</div>
						<h2 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Gravitation</h2>
						<p class="text-lg text-white/60 leading-relaxed max-w-md">
							The attractive force of a coherent, owned vision. It pulls in opportunities, people, and energy — not by seeking, but by the sheer presence of your designed identity field.
						</p>
					</div>
					<div></div>
				</div>
			</div>

			<!-- Questions as Probes -->
			<div class="relative min-h-screen flex items-center">
				<div class="absolute inset-0">
					<ProbesScene client:visible />
				</div>
				<div class="relative z-10 max-w-7xl mx-auto px-8 w-full grid md:grid-cols-2 gap-16 items-center">
					<div></div>
					<div class="md:text-right">
						<div class="text-sm uppercase tracking-[4px] text-cyan-400/70 mb-4">04</div>
						<h2 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Questions as Probes</h2>
						<p class="text-lg text-white/60 leading-relaxed max-w-md md:ml-auto">
							Precision instruments to measure and adjust the geometry of your identity. Each question is a probe sent into your reality — returning data about where you are and what's possible.
						</p>
					</div>
				</div>
			</div>

		</section>

		<!-- CTA -->
		<section class="py-32 border-t border-white/10">
			<div class="max-w-4xl mx-auto px-8 text-center">
				<h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Ready to engineer your identity?</h2>
				<p class="text-xl text-white/50 max-w-xl mx-auto">
					The framework is open. Start exploring or contribute.
				</p>

				<div class="mt-12 flex flex-wrap gap-4 justify-center">
					<a href="/framework" class="px-8 py-3.5 rounded-full bg-white text-black font-medium hover:bg-white/90 transition">
						Explore the Framework
					</a>
					<a href="/big-questions" class="px-8 py-3.5 rounded-full border border-white/20 text-white/70 hover:bg-white/5 transition">
						Big Questions
					</a>
					<a href="/contribute" class="px-8 py-3.5 rounded-full border border-white/10 text-white/40 hover:text-white/70 hover:border-white/20 transition">
						Contribute
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
