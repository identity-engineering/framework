---
import { neighbors, type ConceptId, concepts } from '../../lib/concepts';

interface Props {
	id: ConceptId;
}

const { id } = Astro.props;
const { prev, next } = neighbors(id);
const current = concepts.find((c) => c.id === id)!;
---

<section class="border-t border-white/10 py-16 px-6">
	<div class="mx-auto max-w-4xl">
		<!-- Sibling strip -->
		<div class="mb-12 flex flex-wrap gap-2">
			{
				concepts.map((c) => (
					<a
						href={c.href}
						class:list={[
							'rounded-full border px-3 py-1.5 text-xs tracking-wide transition',
							c.id === id
								? 'border-white/25 bg-white/10 text-white'
								: 'border-white/10 text-white/40 hover:border-white/20 hover:text-white/70',
						]}
					>
						{c.shortTitle}
					</a>
				))
			}
		</div>

		<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
			{
				prev ? (
					<a href={prev.href} class="group text-white/40 transition hover:text-white/80">
						<div class="mb-1 text-xs uppercase tracking-[3px] text-white/25">Previous</div>
						<div class="text-lg font-medium text-white/70 group-hover:text-white">← {prev.shortTitle}</div>
					</a>
				) : (
					<a href="/framework" class="text-white/40 transition hover:text-white/70">
						<div class="mb-1 text-xs uppercase tracking-[3px] text-white/25">Overview</div>
						<div class="text-lg">← Framework</div>
					</a>
				)
			}

			<a
				href="/framework"
				class="text-center text-sm uppercase tracking-widest text-white/30 transition hover:text-white/60"
			>
				All concepts
			</a>

			{
				next ? (
					<a href={next.href} class="group text-right text-white/40 transition hover:text-white/80 sm:ml-auto">
						<div class="mb-1 text-xs uppercase tracking-[3px] text-white/25">Next</div>
						<div class="text-lg font-medium text-white/70 group-hover:text-white">{next.shortTitle} →</div>
					</a>
				) : (
					<a href="/big-questions" class="text-right text-white/40 transition hover:text-white/70 sm:ml-auto">
						<div class="mb-1 text-xs uppercase tracking-[3px] text-white/25">Frontier</div>
						<div class="text-lg">Big Questions →</div>
					</a>
				)
			}
		</div>

		<p class="mt-10 text-center text-xs text-white/25">
			{current.layerLabel} · Identity Engineering Framework
		</p>
	</div>
</section>
