---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Identity Engineering | Physics-informed framework for human agency in the AI era">
	<main class="max-w-5xl mx-auto px-6">
		<!-- Hero -->
		<section class="min-h-[70vh] flex flex-col justify-center pt-16">
			<div class="max-w-3xl">
				<h1 class="text-6xl font-bold tracking-tighter mb-6">
					Identity as<br />
					<span class="text-white/90">a designable system.</span>
				</h1>
				<p class="text-2xl text-white/70 max-w-xl">
					A physics-informed, engineering-driven framework for consciously shaping and augmenting human identity and agency in the AI era.
				</p>

				<div class="flex gap-4 mt-10">
					<a href="#concepts" 
					   class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white text-black font-medium hover:bg-white/90 transition">
						Explore the concepts
					</a>
					<a href="/framework" 
					   class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl border border-white/20 hover:bg-white/5 transition">
						Read the framework
					</a>
				</div>
			</div>
		</section>

		<!-- Core Concepts -->
		<section id="concepts" class="py-20">
			<div class="mb-12">
				<h2 class="text-4xl font-semibold tracking-tight">Core Concepts</h2>
				<p class="text-xl text-white/60 mt-3 max-w-2xl">
					We model identity using principles from physics — making it visible, measurable, and designable.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8">
				<!-- Mass -->
				<div class="border border-white/10 rounded-3xl p-8">
					<div class="text-sm uppercase tracking-[3px] text-white/50 mb-3">01</div>
					<h3 class="text-3xl font-semibold mb-4">Mass</h3>
					<p class="text-white/70 text-lg">
						The depth and substance of your personal and professional stake. Not volume, but density and weight.
					</p>
					<div class="mt-8 h-64 bg-white/5 rounded-2xl flex items-center justify-center text-white/40">
						<!-- D3 Visualization: Mass -->
						<div class="text-center">
							<div class="text-sm mb-2">[D3 Visualization]</div>
							<div class="text-xs">Stake Depth & Density</div>
						</div>
					</div>
				</div>

				<!-- Curvature -->
				<div class="border border-white/10 rounded-3xl p-8">
					<div class="text-sm uppercase tracking-[3px] text-white/50 mb-3">02</div>
					<h3 class="text-3xl font-semibold mb-4">Curvature</h3>
					<p class="text-white/70 text-lg">
						How a strong vision warps what appears possible or inevitable in your reality.
					</p>
					<div class="mt-8 h-64 bg-white/5 rounded-2xl flex items-center justify-center text-white/40">
						<!-- D3 Visualization: Curvature -->
						<div class="text-center">
							<div class="text-sm mb-2">[D3 Visualization]</div>
							<div class="text-xs">Warping of Possibility Space</div>
						</div>
					</div>
				</div>

				<!-- Gravitation -->
				<div class="border border-white/10 rounded-3xl p-8">
					<div class="text-sm uppercase tracking-[3px] text-white/50 mb-3">03</div>
					<h3 class="text-3xl font-semibold mb-4">Gravitation</h3>
					<p class="text-white/70 text-lg">
						The attractive force of a coherent, owned vision. It pulls in opportunities, people, and energy.
					</p>
					<div class="mt-8 h-64 bg-white/5 rounded-2xl flex items-center justify-center text-white/40">
						<!-- D3 Visualization: Gravitation -->
						<div class="text-center">
							<div class="text-sm mb-2">[D3 Visualization]</div>
							<div class="text-xs">Attraction of Energy & Opportunity</div>
						</div>
					</div>
				</div>

				<!-- Questions as Probes -->
				<div class="border border-white/10 rounded-3xl p-8">
					<div class="text-sm uppercase tracking-[3px] text-white/50 mb-3">04</div>
					<h3 class="text-3xl font-semibold mb-4">Questions as Probes</h3>
					<p class="text-white/70 text-lg">
						Precision tools to measure and adjust the current geometry of your identity and reality.
					</p>
					<div class="mt-8 h-64 bg-white/5 rounded-2xl flex items-center justify-center text-white/40">
						<!-- D3 Visualization: Probes -->
						<div class="text-center">
							<div class="text-sm mb-2">[D3 Visualization]</div>
							<div class="text-xs">Interactive Measurement</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Call to action -->
		<section class="py-20 border-t border-white/10">
			<div class="max-w-2xl">
				<h2 class="text-4xl font-semibold tracking-tight">Ready to engineer your identity?</h2>
				<p class="mt-4 text-xl text-white/70">
					The framework is open. Start exploring or contribute.
				</p>

				<div class="mt-8 flex gap-4">
					<a href="/framework" class="px-8 py-3.5 rounded-xl bg-white text-black font-medium hover:bg-white/90 transition">
						Explore the Framework
					</a>
					<a href="/contribute" class="px-8 py-3.5 rounded-xl border border-white/20 hover:bg-white/5 transition">
						How to Contribute
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>