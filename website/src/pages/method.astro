---
import Layout from '../layouts/Layout.astro';

const skillCoachUrl = '/skills/identity-engineer';
const skillContributorUrl = '/skills/identity-engineer-contributor';

const skillCoach = `# Identity Engineer Skill

## Purpose
Support a person in strengthening identity coherence and sharpening vision through structured dialogue.

## Operating rules
1. Start with current state clarity (facts before stories).
2. Distinguish identity continuity from role performance.
3. Work with one concrete future direction at a time.
4. End every session with one owned commitment in the next 72 hours.
5. Never present this as therapy or diagnosis.

## Session protocol
1) State Differential: 3 stabilizers, 3 frictions.
2) Vision Gradient: one directional sentence.
3) Probe: test coherence with one hard question.
4) Ownership Move: one concrete next action.

## Output format
- State Summary
- Direction Summary
- Probe Insight
- 72h Commitment
- Follow-up Question for next session`;

const skillContributor = `# Identity Engineer Contributor Skill

## Purpose
Guide contributors to improve Identity Engineering content with clarity, rigor, and boundary discipline.

## Contribution rules
1. Preserve distinction: core source theory vs IE interpretation vs IE additions.
2. Mark claims as conceptual, formal, or empirical where relevant.
3. Avoid overclaim language (no universal framing, no pseudo-certainty).
4. Keep analogies explicit as analogies unless formal mapping exists.
5. Maintain public transparency on open gaps and limitations.

## Review checklist
- Is the original source theory represented fairly?
- Is IE inspiration clearly separated from IE additions?
- Are scope and non-use boundaries visible?
- Is wording precise and non-guru-like?
- Are references and links present where needed?

## Output format
- Proposed change
- Why it improves rigor
- Scope/boundary impact
- Suggested follow-up edits`; 
---

<Layout title="Method | Identity Engineering">
	<main class="min-h-screen">
		<section class="border-b border-white/10 px-6 pt-28 pb-16">
			<div class="mx-auto max-w-3xl">
				<div class="mb-4 text-sm uppercase tracking-[4px] text-white/40">Method</div>
				<h1 class="text-5xl font-bold tracking-tighter text-white md:text-6xl leading-[0.95]">
					Tell your agent to add these skills.
				</h1>
				<p class="mt-6 max-w-2xl text-xl font-light leading-relaxed text-white/50">
					Two ready-to-use skills for coaching and contribution quality.
					Copy full text or copy the skill URL path for your agent workflow.
				</p>
			</div>
		</section>

		<section class="px-6 py-16 border-t border-white/10">
			<div class="mx-auto max-w-4xl space-y-10 text-white/55">
				<article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
					<h2 class="text-2xl font-semibold text-white mb-4">Skill 1: Identity Engineer Skill</h2>
					<div class="mb-4">
						<label for="skill-url-1" class="block text-sm text-white/50 mb-2">Skill URL path</label>
						<div class="flex gap-2">
							<input id="skill-url-1" class="flex-1 rounded-xl border border-white/15 bg-black/30 px-3 py-2 text-sm text-white/80" value={skillCoachUrl} readonly />
							<button class="copy-btn rounded-xl border border-white/20 px-4 py-2 text-sm text-white/80 hover:bg-white/5" data-copy-target="skill-url-1">Copy URL</button>
						</div>
					</div>
					<label for="skill-text-1" class="block text-sm text-white/50 mb-2">Skill text</label>
					<textarea id="skill-text-1" class="w-full min-h-[340px] rounded-xl border border-white/15 bg-black/30 p-4 text-sm text-white/85 leading-relaxed" readonly>{skillCoach}</textarea>
					<div class="mt-3">
						<button class="copy-btn rounded-xl border border-white/20 px-4 py-2 text-sm text-white/80 hover:bg-white/5" data-copy-target="skill-text-1">Copy Skill Text</button>
					</div>
				</article>

				<article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
					<h2 class="text-2xl font-semibold text-white mb-4">Skill 2: Identity Engineer Contributor Skill</h2>
					<div class="mb-4">
						<label for="skill-url-2" class="block text-sm text-white/50 mb-2">Skill URL path</label>
						<div class="flex gap-2">
							<input id="skill-url-2" class="flex-1 rounded-xl border border-white/15 bg-black/30 px-3 py-2 text-sm text-white/80" value={skillContributorUrl} readonly />
							<button class="copy-btn rounded-xl border border-white/20 px-4 py-2 text-sm text-white/80 hover:bg-white/5" data-copy-target="skill-url-2">Copy URL</button>
						</div>
					</div>
					<label for="skill-text-2" class="block text-sm text-white/50 mb-2">Skill text</label>
					<textarea id="skill-text-2" class="w-full min-h-[340px] rounded-xl border border-white/15 bg-black/30 p-4 text-sm text-white/85 leading-relaxed" readonly>{skillContributor}</textarea>
					<div class="mt-3">
						<button class="copy-btn rounded-xl border border-white/20 px-4 py-2 text-sm text-white/80 hover:bg-white/5" data-copy-target="skill-text-2">Copy Skill Text</button>
					</div>
				</article>
			</div>
		</section>
	</main>

	<script>
		document.querySelectorAll('.copy-btn').forEach((button) => {
			button.addEventListener('click', async () => {
				const targetId = button.getAttribute('data-copy-target');
				if (!targetId) return;
				const target = document.getElementById(targetId);
				if (!target) return;

				const text = target instanceof HTMLTextAreaElement || target instanceof HTMLInputElement
					? target.value
					: target.textContent || '';

				try {
					await navigator.clipboard.writeText(text);
					const old = button.textContent;
					button.textContent = 'Copied';
					setTimeout(() => {
						button.textContent = old;
					}, 1200);
				} catch {
					const old = button.textContent;
					button.textContent = 'Copy failed';
					setTimeout(() => {
						button.textContent = old;
					}, 1200);
				}
			});
		});
	</script>
</Layout>
