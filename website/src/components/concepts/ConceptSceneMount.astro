---
/**
 * Client-only R3F mount for framework concept cards.
 * Injects Vite React-refresh preamble before loading any .tsx (dev only).
 */
interface Props {
	scene: 'mass' | 'curvature' | 'rotation' | 'gravitation' | 'frequency' | 'emergence' | 'probes' | 'stem';
}

const { scene } = Astro.props;
---

<div
	class="absolute inset-0 w-full h-full min-h-[240px]"
	data-concept-mount={scene}
></div>

<script>
	import { ensureReactPreamble } from '../../lib/ensureReactPreamble';

	const loaders = {
		mass: () => import('./MassScene.tsx'),
		curvature: () => import('./CurvatureScene.tsx'),
		rotation: () => import('./RotationScene.tsx'),
		gravitation: () => import('./GravitationScene.tsx'),
		frequency: () => import('./FrequencyScene.tsx'),
		emergence: () => import('./EmergenceScene.tsx'),
		probes: () => import('./ProbesScene.tsx'),
		stem: () => import('./StemScrollScene.tsx'),
	};

	async function mountEl(el) {
		if (el.getAttribute('data-mounted') === '1') return;
		el.setAttribute('data-mounted', '1');

		const sceneName = el.getAttribute('data-concept-mount');
		const load = loaders[sceneName];
		if (!load) {
			console.error('[ConceptSceneMount] unknown scene', sceneName);
			return;
		}

		try {
			await ensureReactPreamble();
			const { createElement } = await import('react');
			const { createRoot } = await import('react-dom/client');
			const mod = await load();
			createRoot(el).render(createElement(mod.default));
		} catch (err) {
			console.error('[ConceptSceneMount] failed to mount', sceneName, err);
			el.innerHTML =
				'<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#71717a;font-size:12px;font-family:system-ui">Scene failed to load</div>';
		}
	}

	function mountAll() {
		const nodes = document.querySelectorAll('[data-concept-mount]');
		for (let i = 0; i < nodes.length; i++) {
			mountEl(nodes[i]);
		}
	}

	mountAll();
</script>
