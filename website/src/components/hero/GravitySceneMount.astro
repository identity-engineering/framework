---
/**
 * Client-only mount for GravityScene.
 * Injects Vite React-refresh preamble before loading any .tsx (dev only).
 */
---

<div id="gravity-scene-root" class="absolute inset-0" data-gravity-root></div>

<script>
	import { ensureReactPreamble } from '../../lib/ensureReactPreamble';

	async function mount() {
		const el = document.querySelector('[data-gravity-root]');
		if (!el || el.getAttribute('data-mounted') === '1') return;
		el.setAttribute('data-mounted', '1');

		await ensureReactPreamble();

		const { createElement } = await import('react');
		const { createRoot } = await import('react-dom/client');
		const { default: GravityScene } = await import('./GravityScene.tsx');

		createRoot(el).render(createElement(GravityScene));
	}

	mount().catch((err) => console.error('[GravitySceneMount]', err));
</script>
