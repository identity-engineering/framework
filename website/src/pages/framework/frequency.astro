---
import Layout from '../../layouts/Layout.astro';
import ConceptPageHero from '../../components/concepts/ConceptPageHero.astro';
import ConceptPager from '../../components/concepts/ConceptPager.astro';
import { getConcept } from '../../lib/concepts';

const c = getConcept('frequency');
---

<Layout title={`${c.title} | Identity Engineering`}>
	<main class="min-h-screen">
		<ConceptPageHero
			scene={c.scene}
			tag={`${c.tag} · ${c.layerLabel}`}
			title={c.title}
			lede={c.blurb}
			scrollHint={c.scrollHint}
		/>

		<section class="border-t border-white/10 px-6 py-24">
			<div class="mx-auto max-w-3xl space-y-8 text-lg leading-relaxed text-white/55">
				<div class="mb-2 text-sm uppercase tracking-[4px] text-white/40">Definition</div>
				<h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
					The dynamic state of the tension continuum.
				</h2>
				<p>
					<strong class="text-white/80">Frequency</strong> is the engineering descriptor of the high-dimensional tension continuum in which identities exist and interact. It captures the spectrum of characteristic oscillation frequencies, resonance conditions and damping ratios that determine how an identity’s internal tension field evolves over time.
				</p>
				<p>
					Frequency is scale-aware: the same conceptual language applies both to individual identities and to emergent collective identities, even though the characteristic frequencies and relevant damping mechanisms differ across scales.
				</p>
			</div>
		</section>

		<section class="border-t border-white/10 bg-white/[0.02] px-6 py-24">
			<div class="mx-auto max-w-3xl">
				<div class="mb-6 text-sm uppercase tracking-[4px] text-white/40">Mechanics</div>
				<ul class="space-y-6 text-lg text-white/55">
					<li class="border-l border-white/15 pl-5">
						<strong class="text-white/80">Tension field:</strong> The high-dimensional continuum of internal stress and deflection an identity is permanently exposed to.
					</li>
					<li class="border-l border-white/15 pl-5">
						<strong class="text-white/80">Frequency spectrum:</strong> The characteristic rates at which tension oscillates and changes. These frequencies encode responsiveness to internal conflicts and external perturbations.
					</li>
					<li class="border-l border-white/15 pl-5">
						<strong class="text-white/80">Resonance:</strong> Frequency matching between identities or between an identity and idea-clusters, producing mutual amplification and energetically favourable coupling.
					</li>
					<li class="border-l border-white/15 pl-5">
						<strong class="text-white/80">Damping (general):</strong> The rate at which tension oscillations decay. It controls energy dissipation and modal stability. Damping is a general parameter of any tension field. Its specific, higher-order application as regulatory or collective damping is treated in the Collective Identity layer (see Damping).
					</li>
				</ul>
			</div>
		</section>

		<section class="border-t border-white/10 px-6 py-24">
			<div class="mx-auto max-w-3xl text-lg leading-relaxed text-white/55">
				<p>
					<strong class="text-white/80">Engineering work:</strong> Develop sensitivity to the frequency signature of one’s own tension field and of relevant relational fields. Shape internal damping where possible and respond intelligently to external damping inputs.
				</p>
			</div>
		</section>

		<ConceptPager id="frequency" />
	</main>
</Layout>
